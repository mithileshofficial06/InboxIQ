# ============================================
# InboxIQ — Environment Variables
# ============================================
# Copy this file to .env and fill in your actual credentials
# NEVER commit .env to git — it's in .gitignore

# ============================================
# BACKEND SERVICE (.env at root)
# ============================================

# --- General ---
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000

# --- Google OAuth (https://console.cloud.google.com/apis/credentials) ---
GOOGLE_CLIENT_ID=your_rotated_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_rotated_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3001/auth/google/callback

# --- Supabase (https://supabase.com/dashboard/projects) ---
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
DATABASE_URL=postgresql://postgres:your_password@db.your-project-id.supabase.co:5432/postgres

# --- Redis/Upstash (https://console.upstash.com/redis) ---
REDIS_HOST=https://your-redis-id.upstash.io
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password

# --- JWT Secret (Generate: openssl rand -hex 32) ---
JWT_SECRET=your_random_32_char_hex_string

# --- AI Microservice ---
AI_SERVICE_URL=http://localhost:8000

# --- Gemini API Key (https://aistudio.google.com/app/apikey) ---
GEMINI_API_KEY=your_gemini_api_key

# ============================================
# FRONTEND SERVICE (frontend/.env.local)
# ============================================
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_AI_URL=http://localhost:8000

# ============================================
# AI SERVICE (ai-service/.env)
# ============================================
# Copy DATABASE_URL and GEMINI_API_KEY from above
DATABASE_URL=postgresql://postgres:your_password@db.your-project-id.supabase.co:5432/postgres
GEMINI_API_KEY=your_gemini_api_key
