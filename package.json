{
  "name": "inboxiq",
  "version": "1.0.0",
  "private": true,
  "description": "AI-Powered Gmail Analytics Dashboard",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "cd backend && npm run dev",
    "dev:ai": "cd ai-service && uvicorn app.main:app --reload --port 8000",
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\""
  }
}
